# ─────────────────────────────────────────────────────────────
#  Cygnusa Guardian — .gitignore
# ─────────────────────────────────────────────────────────────

# ── AI / IDE Brain Context ──────────────────────────────────
🧠*.md
Brain Context*.md
*.brain.md
.gemini/
.cursor/
.windsurf/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ── Virtual Environments ────────────────────────────────────
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ── Secrets & Environment Variables ────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
*.pem
*.key
*.p12
*.pfx

# ── Database & Runtime Artifacts ────────────────────────────
*.db
*.sqlite
*.sqlite3
*.log
*.pid

# ── Runtime Directories (generated by app) ──────────────────
uploads/
snapshots/
backend/uploads/
backend/snapshots/
backend/logs/

# ── Node / Frontend ─────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/install-state.gz

# ── Testing ─────────────────────────────────────────────────
backend/.pytest_cache/
frontend/coverage/

# ── Docker ──────────────────────────────────────────────────
# (docker-compose.yml and Dockerfiles are intentionally tracked)

# ── OS Artifacts ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE & Editor Artifacts ──────────────────────────────────
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Misc ────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
