# Cygnusa Guardian - Backend Environment Variables
# Copy this to .env and fill in your values

# ─── Core ────────────────────────────────────────────────────────────────────
ENV=development                          # development | production
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./cygnusa.db      # dev default (SQLite)
# DATABASE_URL=postgresql://user:pass@host:5432/cygnusa   # production (PostgreSQL)

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_jwt_key_here_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=12

# ─── AI Engine ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Magic Link ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173       # Production: https://cygnusa-guardian.vercel.app
MAGIC_LINK_TTL_HOURS=72                 # Link expiry in hours

# ─── Email (SMTP for Magic Links) ────────────────────────────────────────────
# Leave blank to use dev mode (links printed to console instead of emailed)
SMTP_HOST=smtp.gmail.com                # or smtp.sendgrid.net, smtp.resend.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here        # For Gmail: use App Password, not your main password
SMTP_FROM=noreply@cygnusa.ai            # Optional: display From address
